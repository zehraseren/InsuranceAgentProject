@model ForecastViewModel

@{
    ViewData["Title"] = "Index";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Poliçe Satış Tahminleri</h5>
        </div>
        <div class="table-responsive mt-3">
            <table class="table align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>Gelecek Ay</th>
                        <th>Tahmin</th>
                        <th>Minimum</th>
                        <th>Maksimum</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.Month</td>
                            <td>@item.Forecasted.ToString("N0")</td>
                            <td>@item.LowerBound.ToString("N0")</td>
                            <td>@item.UpperBound.ToString("N0")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>