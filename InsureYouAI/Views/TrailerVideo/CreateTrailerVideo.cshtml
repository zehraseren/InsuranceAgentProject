@model CreateTrailerVideoDto

@{
    ViewData["Title"] = "CreateTrailerVideo";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Tanıtım Videosu Güncelleme</h5>
            <br />
            <br />
        </div>
        <form method="post">
            <label>Başlık</label>
            <input type="text" asp-for="Title" class="form-control" />
            <br />
            <label>Kapak Fotoğrafı Url</label>
            <input type="text" asp-for="CoverImageUrl" class="form-control" />
            <br />
            <label>Video Url</label>
            <input type="text" asp-for="VideoUrl" class="form-control" />
            <br />
            <div class="d-flex justify-content-end mt-4 none-border">
                <button class="btn btn-outline-success me-3 btn-rounded">Güncelle</button>
                <a href="/TrailerVideo/TrailerVideoList/" class="btn btn-outline-danger me-2 btn-rounded">Vazgeç</a>
            </div>
        </form>
    </div>
</div>