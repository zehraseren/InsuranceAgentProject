@model List<ResultTrailerVideoDto>

@{
    ViewData["Title"] = "TrailerVideoList";
    Layout = "~/Views/AdminLayout/Index.cshtml";
    bool isAny = Model.Any();
}

<div class="card">
    <div class="card-body">
        <div class="d-flex align-items-center">
            <h5 class="mb-0">Tanıtım Videosu Listesi</h5>
            <br />
            <form class="ms-auto position-relative">
                <div class="position-absolute top-50 translate-middle-y search-icon px-3"><i class="bi bi-search"></i></div>
                <input class="form-control ps-5" type="text" placeholder="Ara">
            </form>
        </div>
        <div class="table-responsive mt-3">
            <table class="table align-middle">
                <thead class="table-secondary">
                    <tr>
                        <th>Başlık</th>
                        <th>Videoyu Aç</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Title</td>
                            <td>
                                <a href="@item.VideoUrl" class="btn btn-outline-dark">Videoyu Aç</a>
                            </td>
                            <td>
                                <div class="table-actions d-flex align-items-center gap-3 fs-6">
                                    <!-- Update -->
                                    <a href="/TrailerVideo/UpdateTrailerVideo/@item.TrailerVideoId" class="text-success" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Güncelle"><i class="bi bi-pencil-fill"></i></a>
                                
                                    <!-- Delete -->
                                    <a href="/TrailerVideo/DeleteTrailerVideo/@item.TrailerVideoId" class="text-danger" data-bs-toggle="tooltip" data-bs-placement="bottom" title="Sil"><i class="bi bi-trash-fill"></i></a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <a href="/TrailerVideo/CreateTrailerVideo/" class="btn btn-outline-primary @(isAny ? "disabled" : "")">Yeni Tanıtım Videosu Girişi</a>
        </div>
    </div>
</div>