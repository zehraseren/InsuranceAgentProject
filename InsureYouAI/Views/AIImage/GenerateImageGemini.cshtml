@model string

@{
    ViewData["Title"] = "GenerateImageGemini";
    Layout = "~/Views/AdminLayout/Index.cshtml";
}

<div class="card">
    <div class="card-body">
        <h5 class="mb-4">Google Gemini ile Görsel Oluşturma</h5>
        
        <form method="post">
            <div class="form-group">
                <label>Prompt Girişi Yapınız:</label>
                <input type="text" name="prompt" class="form-control" placeholder="Örn: Karlı dağlar üzerinde uçan bir ejderha..." required />
            </div>
            <div class="d-flex justify-content-end mt-4">
                <button type="submit" class="btn btn-outline-success btn-rounded">Görseli Oluştur</button>
            </div>
        </form>

        @if (ViewBag.error != null)
        {
            <div class="alert alert-danger mt-3">
                <strong>Hata:</strong> @ViewBag.error
            </div>
        }

        @if (!string.IsNullOrEmpty(Model))
        {
            <div class="mt-4 text-center">
                <h3>Oluşturulan Görsel:</h3>
                <hr />
                <img src="@Model" alt="Google Gemini Görseli" class="img-fluid rounded shadow" style="max-width:512px; border: 1px solid #ddd;" />
                <br />
                <a href="@Model" download="gemini-image.png" class="btn btn-sm btn-primary mt-2">Görseli İndir</a>
            </div>
        }
    </div>
</div>